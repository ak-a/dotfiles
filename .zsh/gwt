_gwt_build_complete_help() {
    local c

    _gwt_complete_help=()
    for c in "${_gwt_commands[@]}" "${_gwt_no_wt_commands[@]}" "${_gwt_remote_commands[@]}"; do
        _gwt_complete_help+=("${c}	${_gwt_help[${c}]}")
    done
}

