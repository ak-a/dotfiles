_gwt_jira_description2branch_directory() { # cc_type jira description...
    # returns something suitable for a branch and directory
    shopt -s extglob
    local cc_type="$1"
    shift
    local jira="$1"
    shift
    # shellcheck disable=SC2124
    local description="$@"
    local branch="${description// /-}"
    branch="${branch//+([^[:alnum:]-])/.}"
    branch="${branch//--/-}"
    branch="${branch//../.}"
    branch="${branch//.-/.}"
    branch="${branch//-./-}"
    branch="${USER}/${cc_type}-${jira}-${branch}"
    local directory="${cc_type}-${jira}-${description//+([^[:alnum:]])/-}"

    echo "${branch::63}" "${directory::63}"
}

_gwt_help[branch]='adds a worktree for an existing branch'
function _gwtsub_branch() { # branch
    local branch=${1?Missing branch}
    local directory=${branch:gs/\//-}       # turn slash to -

    (
        builtin cd ${_gwt_bare?}
        git fetch --all --prune --refetch \
            && pushd ${_gwt_default_branch?} \
            && git checkout ${_gwt_default_branch} \
            && git pull \
            && popd \
            && git worktree add ./${directory} ${branch} || return $?
    ) || return $?
    dirs -c
    cd ${_gwt_bare}/${directory} || return $?

    # now we setup the worktree branch
    # install pre-commit if repo has config
    [[ -r .pre-commit-config.yaml ]] && typeset -f pre-commit > /dev/null && pre-commit install
}

_gwt_help[newbranch]='creates a new git worktree using <cc> and <jira>'
function _gwtsub_newbranch() { # cc_type JIRA
    local cc_type=${1?Missing conventional commit type}
    local jira=${2?Missing JIRA ticket}
    local branch directory
    if [[ -z $3 ]]; then
        read -r branch directory < <(_gwt_jira_description2branch_directory ${cc_type} ${jira} "$(_gwt_jira_issue_description ${jira})")
    else
        directory="${cc_type}-${jira}-$3"
        branch=${USER}/${directory}
    fi

    #typeset -p cc_type jira branch directory
    #return 0

    (
        builtin cd ${_gwt_bare?}
        git fetch --all --prune --refetch \
            && pushd ${_gwt_default_branch?} \
            && git checkout ${_gwt_default_branch} \
            && git pull \
            && popd \
            && git worktree add -b ${branch} ${directory} || return $?
    ) || return $?
    dirs -c
    cd ${_gwt_bare}/${directory} || return $?
    [[ -r mise.toml ]] && mise trust

    # now we setup the worktree branch
    # install pre-commit if repo has config
    [[ -r .pre-commit-config.yaml ]] && typeset -f pre-commit > /dev/null && pre-commit install
    # set the upstream for future push
    git push --set-upstream origin ${branch}

    _git_set_commit_message ${cc_type} ${jira}

    # if we have done a claude /init before then lets give claude a few clues
    [[ -r ../CLAUDE.md && ! -r CLAUDE.md ]] && ln../CLAUDE.md .
}

_gwt_comp_newbranch() {
    _arguments \
        ':commit type:( ${_gwt_commit_type[*]} )' \
        ':jira issue:{_gwt_jira_issue_comp}'
}

_git_set_commit_message() { # conventional-commit-type jira-ticket
    cat > .gitmessage << GITMESSAGE
${1:-feat}: ${2:-UPPI} ####SUBJECT WHAT####
GITMESSAGE
    git config commit.template .gitmessage
}

# shellcheck disable=SC2154
_gwt_help[remove]='removes a worktree, if not clean will show details'
function _gwtsub_remove() { # default is _gwt_cwt
    local wt=${1:-${_gwt_cwt?No worktree specified}}
    local orig_dir=${PWD}

    # move to bare root so we're not inside the worktree being removed
    cd ${_gwt_bare} || return $?

    if ! git worktree remove ${wt} $2; then
        cd ${orig_dir}
        git status
        return 1
    fi

    # land in the default branch worktree after successful removal
    cd ${_gwt_bare}/${_gwt_default_branch} || return $?
    return 0
}

_gwt_comp_remove() {
  _gwt_refresh_trees
  _arguments \
    ':worktrees:( ${_gwt_trees[*]} )'
}

_gwt_comp_cd() {
    _gwt_comp_remove
}

# shellcheck disable=SC2154
_gwt_help[fremove]='removes a worktree with force'
function _gwtsub_fremove() { # default is _gwt_cwt
    pushd ${_gwt_bare} || return $?
    local wt=${1:-${_gwt_cwt}}
    git worktree remove ${wt} --force
    popd || popd -n
    return $?
}

# shellcheck disable=SC2154
_gwt_help[list]='list worktrees'
function _gwtsub_list() {
    local tree branch git_status ahead behind clean_status status_fmt

    _gwt_refresh_trees

    if [[ ${1} != -l ]]; then
        printf "%s\n" ${_gwt_trees[*]}
        return 0
    fi

    # do a git status for each one
    status_fmt="%-60s %-65s %-10s %s\n"
    printf "${status_fmt}" "WORKTREE" "BRANCH" "STATUS" "SYNC"
    printf "%s\n" "$(printf '%.0s-' {1..165})"

    for tree in ${_gwt_default_branch} ${_gwt_trees[@]}; do
        (
            cd ${_gwt_bare}/${tree} 2>/dev/null || return

            # Get current branch
            branch=$(git branch --show-current)

            # Check if worktree is clean
            if git diff-index --quiet HEAD -- 2>/dev/null; then
                clean_status="clean"
            else
                clean_status="dirty"
            fi

            # Check ahead/behind status
            ahead=$(git rev-list @{u}..HEAD 2>/dev/null | wc -l | tr -d ' ')
            behind=$(git rev-list HEAD..@{u} 2>/dev/null | wc -l | tr -d ' ')

            if [[ ${ahead} -gt 0 ]] || [[ ${behind} -gt 0 ]]; then
                git_status="↑${ahead} ↓${behind}"
            else
                git_status="synced"
            fi

            printf "${status_fmt}"  "${tree}" "${branch}" "${clean_status}" "${git_status}"
        )
    done
}

# shellcheck disable=SC2154
_gwt_help[clone]='clone and setup of a repository with worktree'
function _gwtsub_clone() {
    setopt local_options BASH_REMATCH
    local dest

    # change dest based on if this is our default GHES and possible default org
    [[ $1 =~ https://([^/]+)/([^/]+)/([^/]+)(.git)?$ ]] || {
        echo "gwt: unexpect clone parameter '$1', expecting https://host/org/repo" >&2
        return 1
    }

    if [[ ${BASH_REMATCH[2]} == "${_gwt_ghes}" ]]; then
        if [[ ${BASH_REMATCH[3]} == "${_gwt_default_org}" ]]; then
            dest=${BASH_REMATCH[4]}
        else
            dest=${BASH_REMATCH[3]}/${BASH_REMATCH[4]}
        fi
    else
        dest=${BASH_REMATCH[2]}/${BASH_REMATCH[3]}/${BASH_REMATCH[4]}
    fi

    echo git clone $1 ${dest} >&2
    git clone --quiet --progress --bare $1 ${dest} || return $?
    cd "${dest}" || return $?

    git config --add remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
    _gwt_get_default_branch
    # shellcheck disable=SC2210
    [[ -z ${_gwt_default_branch} ]] && {
        echo "gwt: can't find default branch" &> 2
        return 1
    }

    git worktree add ./${_gwt_default_branch} ${_gwt_default_branch} \
        && cd ${_gwt_default_branch} || return $?
}

_gwt_run_command_in_another_tree() { # command remote-worktree args...
    local remote_dir=${_gwt_bare}/${1}/${_gwt_subdir}
    shift

    pushd ${remote_dir} && {
        "$@"
        popd || return $?
    }
}

_gwt_help[default]='cd to default branch'
function _gwtsub_default() {
    _gwtsub_refresh || return $?
    cd ${_gwt_bare?}/${_gwt_default_branch?No default branch}
}

# shellcheck disable=SC2120
_gwtsub_help() { # command
    local regex

    [[ $# -eq 0 ]] && {
        cat << USAGE
Usage: gwt <command>
<command> is one of ${_gwt_commands[@]}
USAGE
        return 0
    }

    regex="\<${1}\>"
    [[ ${_gwt_remote_commands[*]} =~ ${regex} ]] || {
        cat << REMOTE_COMMANDS
Usage: gwt <command> <worktree> <args>
run <command> <args> in remote <worktree>
REMOTE_COMMANDS
        return 0
    }
    [[ ${_gwt_commands[*]} =~ ${regex} ]] || {
        echo "gwt: ERROR '${1}' not a command" >&2
        _gwtsub_help
        return 2
    }
    printf "Usage: gwt $1\n%s" ${_gwt_help[$1]}
    return 0
}

