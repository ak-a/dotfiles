gwt() {
    local gwt_command
    local regex="\<${1}\>"
    local worktree command

    [[ $# -eq 0 ]] && {
        echo "gwt: ERROR - no command specified" >&2
        return 128
    }

    if [[ -v _gwt_aliases[$1] ]]; then
        set -- ${_gwt_aliases[$1]} "${@:2}"
    fi

    gwt_command="_gwtsub_${1}"

    if (($_gwt_no_wt_commands[(Ie)$1])); then
        shift
        ${gwt_command} "$@"
        return $?
    fi

    _gwtsub_refresh || return $?

    [[ -z ${_gwt_bare} ]] && {
        echo "gwt: ERROR not in git worktree directory" >&2
        return 1
    }

    [[ ${_gwt_remote_commands[*]} =~ ${regex} ]] && {
        command=$1
        shift
        worktree=$1
        shift
        _gwt_run_command_in_another_tree ${worktree} ${command} "$@"
        return $?
    }

    typeset -f ${gwt_command} > /dev/null 2>&1 || {
        echo "gwt: ERROR - No subcommand ${1}" >&2
        return 128
    }

    shift
    ${gwt_command} "$@"
    return $?
}

# completion...
compdef _gwt_comp gwt
_gwt_comp() {
    local line state

    _arguments -C \
               "1: :->cmds" \
               "*::arg:->args"
    case "$state" in
        cmds)
            _values "dolt command" \
                    ${_gwt_commands[*]}
            ;;
        args)
            _gwt_comp_${line[1]}
            ;;
    esac
}
